# Copy to .env and fill in values from your Supabase project (Settings → API).
# The VITE_-prefixed variables are read by the browser bundle (publishable
# values only — never put service-role keys here). The unprefixed ones are
# read by the SSR / server-function runtime.

VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key
VITE_SUPABASE_PROJECT_ID=your-project-ref

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-anon-key
SUPABASE_PROJECT_ID=your-project-ref

# Server-only. Bypasses RLS — never expose to the browser, never prefix VITE_.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key